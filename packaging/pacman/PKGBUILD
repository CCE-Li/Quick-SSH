# Maintainer: CCE-Li <cce.li@example.com>
# PKGBUILD for Quick-SSH (Arch Linux)
# 原生二进制版本 - 无需 Node.js 依赖

pkgname=quick-ssh
pkgver=1.1.0
pkgrel=1
pkgdesc="🚀 Quick-SSH - Docker-style SSH connection manager with TUI (native binary)"
arch=('x86_64')
url="https://github.com/CCE-Li/Quick-SSH"
license=('MIT')
depends=('glibc' 'openssh')
provides=('quick-ssh')
conflicts=('quick-ssh')
source=("$url/releases/download/v$pkgver/qssh-linux-x64")
sha256sums=('SKIP')

package() {
  install -dm755 "$pkgdir/usr/bin"
  install -m755 "$srcdir/qssh-linux-x64" "$pkgdir/usr/bin/qssh"
}
