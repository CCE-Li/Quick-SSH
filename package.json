{
  "name": "quick-ssh",
  "version": "1.1.4",
  "description": "🚀 Quick-SSH - 仿 Docker 命令行风格的 SSH 连接管理工具（原生二进制版本，无需 Node.js）",
  "keywords": [
    "ssh",
    "powershell",
    "wsl",
    "crt",
    "quick-ssh",
    "qssh",
    "connection-manager",
    "windows",
    "scoop",
    "winget",
    "apt",
    "pacman"
  ],
  "homepage": "https://github.com/CCE-Li/quick-ssh#readme",
  "bugs": {
    "url": "https://github.com/CCE-Li/quick-ssh/issues"
  },
  "license": "MIT",
  "author": "CCE-Li",
  "bin": {
    "qssh": "scripts/qssh.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CCE-Li/quick-ssh.git"
  },
  "scripts": {
    "postinstall": "node src/lib/index.js postinstall",
    "preuninstall": "node src/lib/index.js preuninstall",
    "build": "node scripts/build.js",
    "build:all": "node scripts/build.js --all",
    "build:win": "node scripts/build.js --platform win32",
    "build:linux": "node scripts/build.js --platform linux",
    "build:mac": "node scripts/build.js --platform darwin",
    "prepublishOnly": "node scripts/build.js --all",
    "pack:dry": "npm pack --dry-run"
  },
  "files": [
    "dist/bin/",
    "dist/usr/",
    "src/lib/",
    "src/unix/",
    "src/tui/",
    "scripts/qssh.js"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "win32",
    "linux",
    "darwin"
  ],
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.44.0",
    "postject": "^1.0.0-alpha.6"
  }
}
